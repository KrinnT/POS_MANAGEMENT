generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- USER & AUTH ---
model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  role      Role     @default(WAITER)
  passcode  String?  
  orders    Order[]
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  WAITER
  CHEF
}

// --- RESTAURANT & TABLES ---
model Table {
  id          String   @id @default(uuid())
  name        String   
  status      TableStatus @default(AVAILABLE)
  qrToken     String   @unique
  orders      Order[]
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
}

// --- MENU & INVENTORY ---
model Product {
  id          String   @id @default(uuid())
  name        String
  price       Float
  category    String   
  isAvailable Boolean  @default(true)
  recipeItems Recipe[]
  orderItems  OrderItem[]
}

model Inventory {
  id            String   @id @default(uuid())
  ingredient    String   
  stockQuantity Float
  unit          String   
  minThreshold  Float    
  recipes       Recipe[]
}

model Recipe {
  productId     String
  inventoryId   String
  amount        Float    
  product       Product   @relation(fields: [productId], references: [id])
  inventory     Inventory @relation(fields: [inventoryId], references: [id])
  @@id([productId, inventoryId])
}

// --- ORDER & PAYMENT ---
model Order {
  id            String   @id @default(uuid())
  tableId       String
  userId        String?  
  status        OrderStatus 
  totalAmount   Float
  paymentStatus PayStatus   
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  items         OrderItem[]
  table         Table    @relation(fields: [tableId], references: [id])
  user          User?    @relation(fields: [userId], references: [id])
}

enum OrderStatus {
  PENDING
  PREPARING
  SERVED
  COMPLETED
  CANCELLED
}

enum PayStatus {
  UNPAID
  PARTIAL
  PAID
}

model OrderItem {
  id            String   @id @default(uuid())
  orderId       String
  productId     String
  quantity      Int
  modifiers     Json?    
  status        ItemStatus 
  
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id])
}

enum ItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
}
